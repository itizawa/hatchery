{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "openapi": {
      "dependsOn": ["^build"],
      "outputs": ["openapi.json"]
    },
    "gen-types": {
      "dependsOn": ["@hatchery/server#openapi"],
      "outputs": ["src/api/openapi.gen.ts"]
    },
    "gen-field-specs": {
      "dependsOn": ["@hatchery/common#build"],
      "outputs": ["src/generated/**"]
    },
    "@hatchery/client#build": {
      "dependsOn": ["^build", "gen-types"],
      "outputs": ["dist/**"]
    },
    "db:generate": {
      "cache": false
    },
    "@hatchery/server#test": {
      "dependsOn": ["^build", "@hatchery/server#db:generate"],
      "outputs": ["coverage/**"],
      "env": ["DATABASE_URL"]
    },
    "@hatchery/server#build": {
      "dependsOn": ["^build", "@hatchery/server#db:generate"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "storybook:build": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "@hatchery/docs#storybook:build": {
      "dependsOn": ["@hatchery/common#build", "@hatchery/docs#gen-field-specs"],
      "outputs": ["storybook-static/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
