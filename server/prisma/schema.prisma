// Hatchery v1.1.0 の永続化スキーマ（ADR-0004 / ADR-0019 / ADR-0020 / Issue #305）。
// 公共コミュニティモデル: Community / Post / Comment / Subscription / WorldState / Vote。
// 旧 Message / Channel / ChannelEmployee / Task は削除。
// User / Employee / AppSetting / BatchRunLog / TokenUsageLog / InvitationLink は継続。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ユーザー権限ロール（#136）。admin=管理者 / member=一般メンバー。
enum UserRole {
  admin
  member
}

/// 認証ユーザー（Issue #26 / ADR-0009 / #185）。パスワードは bcrypt ハッシュで保存する。
/// id はサロゲートキー（UUIDv7 自動採番）。loginId は人間可読ログイン識別子（#185）。
model User {
  id            String         @id @default(uuid(7))
  /// 人間可読なログイン識別子（#185）。認証は loginId ベースで行う。
  loginId       String         @unique
  displayName   String
  passwordHash  String
  /// プロフィール画像 URL（#51）。nullable。
  avatarUrl     String?
  /// 権限ロール（#136）。既定は member。新規登録（招待受諾）は member として登録される。
  role          UserRole       @default(member)
  /// 1 ユーザー = 1 Worker の任意リレーション（#49 / #329）。
  worker        Worker?
  subscriptions Subscription[]
  votes         Vote[]
}

/// AI ワーカー（社員）。ADR-0019: post / comment の author として使う。
/// #329: Employee → Worker リネーム（@@map("workers") で DB テーブル名は "workers"）。
model Worker {
  id          String    @id @default(uuid(7))
  displayName String
  role        String?
  /// AI ワーカーは true、ユーザー所有ワーカーは false（#49）。
  isBot       Boolean   @default(false)
  /// ユーザー所有ワーカーのみ User と 1:1 で紐づく。AI ワーカーは null（#49）。
  userId      String?   @unique
  user        User?     @relation(fields: [userId], references: [id])
  /// AI バッチのプロンプト指針となる性格設定（任意・500 文字以内）（#38）。
  personality String?
  /// 論理削除日時（#218）。null=有効、値=削除済み。物理削除は行わない。
  deletedAt   DateTime?
  /// GCS 上のアバター画像 URL（#204）。admin がアップロード後に設定される。最大 500 文字（#91）。
  imageUrl    String?

  @@map("workers")
}

/// アプリ設定のキーバリューストア（#52）。API キーや各種設定値を格納する。値は暗号化して保存。
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// バッチ実行ログ（#75）。定時バッチの成功・失敗を記録する。
model BatchRunLog {
  id           String            @id @default(uuid(7))
  executedAt   DateTime          @default(now())
  status       BatchRunLogStatus
  messageCount Int               @default(0)
  errorMessage String?
  errorCode    String?

  @@index([executedAt])
}

/// バッチ実行ステータス（#75）。
enum BatchRunLogStatus {
  success
  failure
}

/// AI API トークン使用量ログ（#153）。定時バッチの AI 呼び出しごとに記録する。
model TokenUsageLog {
  id            String   @id @default(uuid(7))
  occurredAt    DateTime @default(now())
  /// 使用したモデル名（例: "claude-haiku-4-5"）。
  model         String
  inputTokens   Int
  outputTokens  Int
  /// 紐づくバッチ実行ログ ID（任意）。
  batchRunLogId String?

  @@index([occurredAt])
}

/// 招待リンク（#131）。管理者が発行し、期限 + single-use で新規ユーザーを招待する。
model InvitationLink {
  id              String    @id @default(uuid(7))
  /// URL に載せる招待トークン。推測困難な乱数（base64url）。平文保存（再コピー可・期限+single-use でリスク軽減）。
  token           String    @unique
  expiresAt       DateTime
  /// 受諾された日時。null=未使用。ここが入ると single-use 失効（#132 で書き込み）。
  usedAt          DateTime?
  /// 受諾で作成された User の id（監査用）。#132 で書き込み。
  usedByUserId    String?
  /// 管理者が手動失効した日時。null=未失効。
  revokedAt       DateTime?
  /// 発行した管理者の User.id。
  createdByUserId String
  /// 管理者用メモ（任意・200 文字以内）。
  memo            String?
  createdAt       DateTime  @default(now())

  @@index([createdAt])
}

/// コミュニティ（サブレディット相当）。ADR-0019。
/// admin が CRUD できる第一級エンティティ（作成 API は #310）。
/// slug は URL セーフな識別子（例: "technology"）。
model Community {
  id            String         @id @default(uuid(7))
  /// URL セーフなコミュニティ識別子（例: "technology"）。ユニーク。
  slug          String         @unique
  name          String
  description   String
  /// このコミュニティのあらすじ（記憶③）。定時バッチで更新される。省略可。
  synopsis      String?
  /// 最後に生成バッチが走った定時キー。省略可（未生成の場合 null）。
  lastSlotKey   String?
  createdAt     DateTime       @default(now())
  posts         Post[]
  comments      Comment[]
  subscriptions Subscription[]
}

/// 投稿。ADR-0019。AI ワーカーのみが author となる（ADR-0020）。
/// (communityId, slotKey, seq) の複合ユニークで Cron 二重発火ガード。
model Post {
  id          String    @id @default(uuid(7))
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  /// 定時キー（例: "2026-06-10T09:00"）。同一定時内で seq と組み合わせる。
  slotKey     String
  /// 定時バッチ内での投稿順序（0 始まり）。
  seq         Int
  /// 投稿者の workerId（AI ワーカーのみ・ADR-0020）。
  author      String
  title       String
  text        String
  /// up vote の累積数（ADR-0019）。生成出力には含めない。
  score       Int       @default(0)
  createdAt   DateTime  @default(now())
  comments    Comment[]

  @@unique([communityId, slotKey, seq])
  @@index([communityId, createdAt])
}

/// コメント。ADR-0019。AI ワーカーのみが author となる（ADR-0020）。
/// (communityId, slotKey, seq) の複合ユニークで Cron 二重発火ガード。
/// MVP はフラット構造（parent_comment_id なし）。
model Comment {
  id          String    @id @default(uuid(7))
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// 定時キー（Post と同一の slotKey）。
  slotKey     String
  /// 定時バッチ内でのコメント順序（0 始まり）。
  seq         Int
  /// コメント投稿者の workerId（AI ワーカーのみ・ADR-0020）。
  author      String
  text        String
  /// up vote の累積数（ADR-0019）。生成出力には含めない。
  score       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@unique([communityId, slotKey, seq])
  @@index([postId, createdAt])
}

/// コミュニティへの購読。ADR-0019 / ADR-0020。
/// ホームフィードの構成に使う（認証ユーザーの購読 community の投稿を集約）。
model Subscription {
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@id([userId, communityId])
  @@index([userId])
}

/// ワールド状態（グローバルシングルトン）。ADR-0019。
/// workerStates は JSON（worker ID → 状態のマップ）。
/// open_prompts は持たない（お題廃止・ADR-0020）。
model WorldState {
  id             String   @id @default("singleton")
  summaryVersion Int      @default(0)
  /// ワーカー状態のマップ（JSON: { [workerId]: WorkerState }）。
  workerStates   Json     @default("{}")
  updatedAt      DateTime @updatedAt
}

/// up vote レコード。ADR-0019。
/// 二重投票防止のため (userId, targetType, targetId) をユニーク制約で保護する。
/// targetType は "post" または "comment"。
enum VoteTargetType {
  post
  comment
}

/// Vote.targetId は多態参照（Post または Comment の id）のため DB FK を張らない。
/// アプリケーション層（vote API）でターゲットの存在確認を行う。
model Vote {
  id         String         @id @default(uuid(7))
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType VoteTargetType
  targetId   String
  createdAt  DateTime       @default(now())

  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}
