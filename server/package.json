{
  "name": "@hatchery/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -b",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "batch": "tsx src/batch/index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hatchery/common": "workspace:*",
    "@prisma/client": "^6",
    "express": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5",
    "@types/supertest": "^6",
    "prisma": "^6",
    "supertest": "^7",
    "tsx": "^4"
  }
}
