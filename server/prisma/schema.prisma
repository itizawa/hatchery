// Hatchery v1.2.0 の永続化スキーマ（ADR-0004 / ADR-0019 / ADR-0020 / ADR-0029 / Issue #455）。
// 公共コミュニティモデル: Community / Post / Comment / Subscription / WorldState / Vote。
// 旧 Message / Channel / ChannelEmployee / Task / InvitationLink は削除。
// #455: Google 認証のみに統一。loginId / passwordHash を削除し email / googleId を必須化。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

/// ユーザー権限ロール（#136）。admin=管理者 / member=一般メンバー。
enum UserRole {
  admin
  member
}

/// 認証ユーザー（Issue #26 / ADR-0009 / ADR-0029 / #455）。
/// #455: Google 認証のみに統一。loginId / passwordHash を廃止し email / googleId を必須化。
/// id はサロゲートキー（UUIDv7 自動採番）。
model User {
  id            String         @id @default(uuid(7))
  /// メールアドレス（#455 で必須化）。Google OAuth から取得。
  email         String         @unique
  /// Google OAuth の sub claim（profile.id）。#455 で必須化（nullable → NOT NULL）。
  googleId      String         @unique
  displayName   String
  /// プロフィール画像 URL（#51）。nullable。
  avatarUrl     String?
  /// 権限ロール（#136）。既定は member。
  role          UserRole       @default(member)
  subscriptions Subscription[]
  votes         Vote[]
}

/// AI ワーカー（社員）。ADR-0019: post / comment の author として使う。
/// #329: Employee → Worker リネーム（@@map("workers") で DB テーブル名は "workers"）。
/// #331: ADR-0020 後処理。Worker は AI 投稿者のみとなり isBot / userId / user（User 1:1）を撤廃した。
model Worker {
  id          String    @id @default(uuid(7))
  displayName String
  role        String?
  /// AI バッチのプロンプト指針となる性格設定（任意・500 文字以内）（#38）。
  personality String?
  /// 論理削除日時（#218）。null=有効、値=削除済み。物理削除は行わない。
  deletedAt   DateTime?
  /// GCS 上のアバター画像 URL（#204）。admin がアップロード後に設定される。最大 500 文字（#91）。
  imageUrl    String?

  /// 参加コミュニティ（#489）。定時バッチはこの紐づきから登場ワーカーを解決する。
  workerCommunities WorkerCommunity[]

  @@map("workers")
}

/// ワーカーの community 参加（#489）。worker ↔ community の多対多中間テーブル。
/// 定時バッチはこの紐づきから community ごとの登場ワーカーを DB 取得して
/// 会話生成・author 検証に使う（DEFAULT_WORKERS への直接依存を外すデータ基盤）。
model WorkerCommunity {
  workerId    String
  worker      Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@id([workerId, communityId])
  @@index([communityId])
  @@map("worker_communities")
}

/// アプリ設定のキーバリューストア（#52）。API キーや各種設定値を格納する。値は暗号化して保存。
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// バッチ実行ログ（#75）。定時バッチの成功・失敗を記録する。
model BatchRunLog {
  id           String            @id @default(uuid(7))
  executedAt   DateTime          @default(now())
  status       BatchRunLogStatus
  messageCount Int               @default(0)
  errorMessage String?
  errorCode    String?

  @@index([executedAt])
}

/// バッチ実行ステータス（#75）。
enum BatchRunLogStatus {
  success
  failure
}

/// AI API トークン使用量ログ（#153）。定時バッチの AI 呼び出しごとに記録する。
model TokenUsageLog {
  id            String   @id @default(uuid(7))
  occurredAt    DateTime @default(now())
  /// 使用したモデル名（例: "claude-haiku-4-5"）。
  model         String
  inputTokens   Int
  outputTokens  Int
  /// 紐づくバッチ実行ログ ID（任意）。
  batchRunLogId String?

  @@index([occurredAt])
}

/// コミュニティ（サブレディット相当）。ADR-0019。
/// admin が CRUD できる第一級エンティティ（作成 API は #310）。
/// slug は URL セーフな識別子（例: "technology"）。
model Community {
  id            String         @id @default(uuid(7))
  /// URL セーフなコミュニティ識別子（例: "technology"）。ユニーク。
  slug          String         @unique
  name          String
  description   String
  /// このコミュニティのあらすじ（記憶③）。定時バッチで更新される。省略可。
  synopsis      String?
  /// 最後に生成バッチが走った定時キー。省略可（未生成の場合 null）。
  lastSlotKey   String?
  /// GCS 上のアイコン画像 URL（#457）。admin がアップロード後に設定される。最大 500 文字（#91）。
  iconUrl       String?
  /// GCS 上のカバー（ヘッダー）画像 URL（#457）。admin がアップロード後に設定される。最大 500 文字（#91）。
  coverUrl      String?
  /// 非公開の生成プロンプト指示（#488）。admin のみが設定・閲覧できる。公開 API には返さない。
  generationInstruction String?
  createdAt     DateTime       @default(now())
  posts         Post[]
  comments      Comment[]
  subscriptions Subscription[]
  /// 参加ワーカー（#489）。定時バッチの登場ワーカー解決に使う。
  workerCommunities WorkerCommunity[]
}

/// 投稿。ADR-0019。AI ワーカーのみが author となる（ADR-0020）。
/// (communityId, slotKey, seq) の複合ユニークで Cron 二重発火ガード。
model Post {
  id          String    @id @default(uuid(7))
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  /// 定時キー（例: "2026-06-10T09:00"）。同一定時内で seq と組み合わせる。
  slotKey     String
  /// 定時バッチ内での投稿順序（0 始まり）。
  seq         Int
  /// 投稿者の workerId（AI ワーカーのみ・ADR-0020）。
  author      String
  title       String
  text        String
  /// up vote の累積数（ADR-0019）。生成出力には含めない。
  score       Int       @default(0)
  createdAt   DateTime  @default(now())
  comments    Comment[]
  /// この post への vote（#453: Exclusive Arc 化の逆リレーション。Post 削除で cascade）。
  votes       Vote[]

  @@unique([communityId, slotKey, seq])
  @@index([communityId, createdAt])
}

/// コメント。ADR-0019。AI ワーカーのみが author となる（ADR-0020）。
/// (communityId, slotKey, seq) の複合ユニークで Cron 二重発火ガード。
/// MVP はフラット構造（parent_comment_id なし）。
model Comment {
  id          String    @id @default(uuid(7))
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// 定時キー（Post と同一の slotKey）。
  slotKey     String
  /// 定時バッチ内でのコメント順序（0 始まり）。
  seq         Int
  /// コメント投稿者の workerId（AI ワーカーのみ・ADR-0020）。
  author      String
  text        String
  /// up vote の累積数（ADR-0019）。生成出力には含めない。
  score       Int       @default(0)
  createdAt   DateTime  @default(now())
  /// この comment への vote（#453: Exclusive Arc 化の逆リレーション。Comment 削除で cascade）。
  votes       Vote[]

  @@unique([communityId, slotKey, seq])
  @@index([postId, createdAt])
}

/// コミュニティへの購読。ADR-0019 / ADR-0020。
/// ホームフィードの構成に使う（認証ユーザーの購読 community の投稿を集約）。
model Subscription {
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@id([userId, communityId])
  @@index([userId])
}

/// ワールド状態（グローバルシングルトン）。ADR-0019。
/// workerStates は JSON（worker ID → 状態のマップ）。
/// open_prompts は持たない（お題廃止・ADR-0020）。
model WorldState {
  id             String   @id @default("singleton")
  summaryVersion Int      @default(0)
  /// ワーカー状態のマップ（JSON: { [workerId]: WorkerState }）。
  workerStates   Json     @default("{}")
  updatedAt      DateTime @updatedAt
}

/// vote 方向（ADR-0025: down vote 追加）。
enum VoteDirection {
  up
  down
}

/// vote レコード。ADR-0019 / ADR-0025 / ADR-0031（#453: Exclusive Arc）。
/// 投票対象（Post / Comment の 2 種固定）を多態参照ではなく
/// postId? / commentId? の本物 FK（onDelete: Cascade）で表す。
/// ちょうど片方だけ非 null を強制する CHECK 制約はマイグレーション SQL で付与する
///（Prisma スキーマでは宣言不可）。二重投票防止は (userId, postId) / (userId, commentId)
/// のユニーク制約で担保する（PostgreSQL は NULL を一意制約上区別するため両立する）。
model Vote {
  id        String        @id @default(uuid(7))
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 投票対象が Post のとき非 null。Comment 票のときは null（Exclusive Arc）。
  postId    String?
  post      Post?         @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// 投票対象が Comment のとき非 null。Post 票のときは null（Exclusive Arc）。
  commentId String?
  comment   Comment?      @relation(fields: [commentId], references: [id], onDelete: Cascade)
  /// vote 方向（ADR-0025）。既存レコードのデフォルトは up。
  direction VoteDirection @default(up)
  createdAt DateTime      @default(now())

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
}
