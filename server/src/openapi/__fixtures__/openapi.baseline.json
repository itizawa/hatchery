{
  "openapi": "3.1.0",
  "info": {
    "title": "Hatchery API",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "schemas": {
      "UserRole": {
        "type": "string",
        "enum": [
          "admin",
          "member"
        ],
        "description": "ユーザー権限ロール（#136）"
      },
      "AuthUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "maxLength": 254,
            "format": "email"
          },
          "displayName": {
            "type": "string",
            "maxLength": 100
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "member"
            ]
          },
          "avatarUrl": {
            "type": "string",
            "maxLength": 2048
          }
        },
        "required": [
          "id",
          "email",
          "displayName",
          "role"
        ],
        "description": "認証済みユーザーの公開情報（passwordHash 等は含まない）"
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ],
        "description": "エラー応答（実装の実際の形に準拠）"
      },
      "Worker": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          },
          "role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          },
          "personality": {
            "type": "string",
            "maxLength": 500
          },
          "verbosity": {
            "type": "string",
            "enum": [
              "concise",
              "standard",
              "detailed"
            ]
          },
          "imageUrl": {
            "type": "string",
            "maxLength": 500,
            "format": "uri"
          },
          "deletedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "displayName"
        ],
        "description": "AI ワーカー（id / displayName / role / personality）"
      },
      "UpdateWorker": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          },
          "role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          },
          "personality": {
            "type": "string",
            "maxLength": 500
          },
          "verbosity": {
            "type": "string",
            "enum": [
              "concise",
              "standard",
              "detailed"
            ]
          }
        },
        "description": "Worker 更新リクエストボディ（#38）"
      },
      "CreateWorker": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          },
          "role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 50
          },
          "personality": {
            "type": "string",
            "maxLength": 500
          },
          "verbosity": {
            "type": "string",
            "enum": [
              "concise",
              "standard",
              "detailed"
            ]
          }
        },
        "required": [
          "displayName"
        ],
        "description": "Worker 作成リクエストボディ"
      }