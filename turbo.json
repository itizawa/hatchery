{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "openapi": {
      "dependsOn": ["^build"],
      "outputs": ["openapi.json"]
    },
    "gen-types": {
      "dependsOn": ["@hatchery/server#openapi"],
      "outputs": ["src/api/openapi.gen.ts"]
    },
    "@hatchery/client#build": {
      "dependsOn": ["^build", "gen-types"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
