# client（Vite SPA）の公開環境変数。
# 実値は client/.env.local に置く（.gitignore 対象）。Vite は VITE_ 接頭辞の変数のみブラウザへ公開する。
# 値は client/src/config/env.ts が Zod で検証し、不正値はアプリ起動時にエラーになる。

# server API のベース URL（オリジン）。
# 未設定（または空）なら同一オリジン相対で API を呼ぶ（dev は vite.config.ts の proxy 経由）。
# クロスオリジン配信（Cloudflare Pages × Cloud Run, #78）では Cloud Run の URL を設定する。
# 例: VITE_API_BASE_URL=https://hatchery-xxxxx-an.a.run.app
VITE_API_BASE_URL=

# クライアントのログレベル（任意）。debug / info / warn / error のいずれか。未設定なら info。
VITE_LOG_LEVEL=info

# OGP / シェア時に使う本番ドメイン（#256 / ADR-0008）。index.html の og:url / og:image に注入される。
# 未設定ならビルド時に vite.config.ts の既定値（https://hatchery.pages.dev）が使われる。
# 例: VITE_OGP_URL=https://hatchery.example.com
VITE_OGP_URL=
