# server（Prisma / PostgreSQL）の接続設定。
# 実値は server/.env に置く（.gitignore 対象）。docker での起動例は docs/design/issue-6.md / README 参照。
#
# DB 接続タイムアウトの推奨設定（#73）:
#   connect_timeout : TCP 接続確立の上限（秒）。推奨値 10。
#   pool_timeout    : 接続プールからの取得待ち上限（秒）。推奨値 10。
# REQUIRED in production
DATABASE_URL="postgresql://hatchery:hatchery@localhost:5432/hatchery?schema=public&connect_timeout=10&pool_timeout=10"

# Express API プロセスの待受ポート。
PORT=3000

# --- DDoS/過負荷対策（#34）。すべて任意。未設定なら以下の既定値が使われる。 ---
# レート制限のウィンドウ長（ミリ秒）と、ウィンドウあたりの IP ごと最大リクエスト数。
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
# リクエストボディサイズ上限（express.json の limit 記法。例: "100kb" / "1mb"）。
REQUEST_BODY_LIMIT=100kb
# リクエストタイムアウト（ミリ秒）。超過すると 503 を返す。
REQUEST_TIMEOUT_MS=30000

# --- セキュリティ（#35 / #344）。 ---
# REQUIRED in production: express-session の署名秘密鍵。
# 本番では必ず 32 文字以上のランダム文字列を設定すること（openssl rand -base64 32）。
# 未設定の場合は開発用デフォルト値が使われる（本番には不適切）。
SESSION_SECRET=your-session-secret-here
# CORS で許可するフロントエンドのオリジン（カンマ区切り）。未設定なら全オリジン不許可。
# REQUIRED in production: 具体的なオリジンを設定すること。本番で "*" は禁止。
# 例: CORS_ALLOWED_ORIGINS=https://hatchery.pages.dev
CORS_ALLOWED_ORIGINS=http://localhost:5173
# 注: セキュアヘッダは常時付与（Content-Security-Policy / X-Frame-Options 等）。
# HSTS（Strict-Transport-Security）は NODE_ENV=production のときのみ付与する。

# --- AI 機能（#52）。---
# DB に保存する値を暗号化するための秘密鍵。本番では必ず 32 文字以上のランダム文字列を設定すること。
# 例: openssl rand -base64 32
# 未設定の場合は開発用デフォルト値（hatchery-dev-secret）が使われる（本番には不適切）。
APP_SECRET=your-random-secret-key-here
# Anthropic Claude API キー（管理画面から DB に保存した場合はそちらを優先する）。
ANTHROPIC_API_KEY=sk-ant-api03-...
