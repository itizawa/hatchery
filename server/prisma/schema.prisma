// Hatchery MVP の永続化スキーマ（ADR-0004 / Issue #6 / ADR-0009 / Issue #27）。
// common（@hatchery/common）のドメイン型に対応する最小構成。
// 社員・チャンネル・メッセージ（channel 直接紐づき）・タスク（new/done）。
// Scene は ADR-0009 で廃止した。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ユーザー権限ロール（#136）。admin=管理者 / member=一般メンバー。
enum UserRole {
  admin
  member
}

/// 認証ユーザー（Issue #26 / ADR-0009 / #185）。パスワードは bcrypt ハッシュで保存する。
/// id はサロゲートキー（UUIDv7 自動採番）。loginId は人間可読ログイン識別子（#185）。
model User {
  id           String    @id @default(uuid(7))
  /// 人間可読なログイン識別子（#185）。認証は loginId ベースで行う。
  loginId      String    @unique
  displayName  String
  passwordHash String
  /// プロフィール画像 URL（#51）。nullable。
  avatarUrl    String?
  /// 権限ロール（#136）。既定は member。新規登録（招待受諾）は member として登録される。
  role         UserRole  @default(member)
  /// 1 ユーザー = 1 Employee の任意リレーション（#49）。
  employee     Employee?
}

/// AI 社員。common の EmployeeSchema に対応（id / displayName / role? / isBot / personality?）。
model Employee {
  id          String            @id @default(uuid(7))
  displayName String
  role        String?
  /// AI 社員は true、ユーザー所有社員は false（#49）。
  isBot       Boolean           @default(false)
  /// ユーザー所有社員のみ User と 1:1 で紐づく。AI 社員は null（#49）。
  userId      String?           @unique
  user        User?             @relation(fields: [userId], references: [id])
  tasks       Task[]
  channels    ChannelEmployee[]
  /// AI バッチのプロンプト指針となる性格設定（任意・500 文字以内）（#38）。
  personality String?
  messages    Message[]
}

/// チャンネルのタイプ（#54 / #76）。zatsudan=雑談 / task=仕事 / planning=企画。
enum ChannelType {
  zatsudan
  task
  planning
}

/// 話題の入れ物。common の ChannelSchema に対応（id / label / type）。
/// summary / summaryUpdatedAt は定時バッチの会話生成に使うチャンネルのあらすじ（#53）。
/// 直近 30 件より前の文脈を圧縮した要約で、API（OpenAPI）には公開しないバッチ内部の状態。
model Channel {
  id               String            @id @default(uuid(7))
  label            String
  type             ChannelType       @default(zatsudan)
  summary          String?
  summaryUpdatedAt DateTime?
  members          ChannelEmployee[]
}

/// Employee ↔ Channel の所属（多対多）の明示的中間テーブル（#33）。
/// 1 人の Employee が複数チャンネルに所属でき、1 チャンネルに複数 Employee が所属できる。
model ChannelEmployee {
  channelId  String
  employeeId String
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([channelId, employeeId])
  @@index([employeeId])
}

/// channel に直接紐づく 1 発言（ADR-0009: Scene 廃止）。
/// createdAt でバッチ間の時系列順を保ち、order でバッチ内の発言順を保つ。
/// postedAt はメッセージを表示する日時（#183）。この時刻を過ぎたメッセージのみ一覧に返す。
/// proposalTitle / proposalReason / proposalTargetUrl / issueNumber / issueUrl は
/// 企画 チャンネルの UX 提案メッセージ専用 optional フィールド（#76）。
/// createdEmployeeId は発言者の Employee.id への外部キー（#222）。onDelete: Restrict。
model Message {
  id                String   @id @default(uuid(7))
  createdEmployeeId String
  channel           String
  text              String
  createdAt         DateTime @default(now())
  /// メッセージの表示予約日時（#183）。この時刻を迎えたメッセージのみ listByChannel に返す。
  postedAt          DateTime @default(now())
  order             Int
  proposalTitle     String?
  proposalReason    String?
  proposalTargetUrl String?
  issueNumber       Int?
  issueUrl          String?
  createdEmployee   Employee @relation(fields: [createdEmployeeId], references: [id], onDelete: Restrict)

  @@index([channel, createdAt])
  @@index([channel, postedAt])
  @@index([createdEmployeeId])
}

/// MVP のタスク状態（common の TaskStatusSchema に対応）。
enum TaskStatus {
  new
  done
}

/// 社員が抱えるタスク。common の TaskSchema に対応（id / text / status）。
model Task {
  id         String     @id @default(uuid(7))
  text       String
  status     TaskStatus @default(new)
  employee   Employee?  @relation(fields: [employeeId], references: [id])
  employeeId String?
}

/// アプリ設定のキーバリューストア（#52）。API キーや各種設定値を格納する。値は暗号化して保存。
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// バッチ実行ログ（#75）。定時バッチの成功・失敗を記録する。
model BatchRunLog {
  id           String            @id @default(uuid(7))
  executedAt   DateTime          @default(now())
  status       BatchRunLogStatus
  messageCount Int               @default(0)
  errorMessage String?
  errorCode    String?

  @@index([executedAt])
}

/// バッチ実行ステータス（#75）。
enum BatchRunLogStatus {
  success
  failure
}

/// AI API トークン使用量ログ（#153）。定時バッチの AI 呼び出しごとに記録する。
model TokenUsageLog {
  id           String   @id @default(uuid(7))
  occurredAt   DateTime @default(now())
  /// 使用したモデル名（例: "claude-haiku-4-5"）。
  model        String
  inputTokens  Int
  outputTokens Int
  /// 紐づくバッチ実行ログ ID（任意）。
  batchRunLogId String?

  @@index([occurredAt])
}

/// 招待リンク（#131）。管理者が発行し、期限 + single-use で新規ユーザーを招待する。
model InvitationLink {
  id              String    @id @default(uuid(7))
  /// URL に載せる招待トークン。推測困難な乱数（base64url）。平文保存（再コピー可・期限+single-use でリスク軽減）。
  token           String    @unique
  expiresAt       DateTime
  /// 受諾された日時。null=未使用。ここが入ると single-use 失効（#132 で書き込み）。
  usedAt          DateTime?
  /// 受諾で作成された User の id（監査用）。#132 で書き込み。
  usedByUserId    String?
  /// 管理者が手動失効した日時。null=未失効。
  revokedAt       DateTime?
  /// 発行した管理者の User.id。
  createdByUserId String
  /// 管理者用メモ（任意・200 文字以内）。
  memo            String?
  createdAt       DateTime  @default(now())

  @@index([createdAt])
}
