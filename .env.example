# Hatchery server 環境変数サンプル
# このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env は .gitignore に含まれており、リポジトリにコミットされません。

# PostgreSQL 接続 URL（必須: DB 機能を使う場合）
DATABASE_URL=postgresql://user:password@localhost:5432/hatchery

# Express セッション署名シークレット（本番では必須・強いランダム値を使うこと）
SESSION_SECRET=your-session-secret-here

# AES-256-GCM 暗号鍵のシークレット（本番では必須・強いランダム値を使うこと）
APP_SECRET=your-app-secret-here

# Google OAuth 2.0 設定（#343 / ADR-0027）
# Google Cloud Console で OAuth 2.0 クライアント ID を作成し、以下に設定してください。
# 未設定の場合、Google ログインエンドポイントは無効化されます。
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# CORS 許可オリジン（カンマ区切り。本番では具体的なオリジンを設定）
# CORS_ALLOWED_ORIGINS=http://localhost:5173

# API サーバーポート（デフォルト: 3000）
# PORT=3000
