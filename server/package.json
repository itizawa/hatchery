{
  "name": "@hatchery/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -b",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "batch:post": "tsx src/batch/postBatchIndex.ts",
    "batch:comment": "tsx src/batch/commentBatchIndex.ts",
    "release-notes": "tsx src/scripts/generateReleaseNotes.ts",
    "cleanup:worker-avatars": "tsx src/scripts/cleanupDeadWorkerAvatarUrls.ts",
    "backfill:news-post-urls": "tsx src/scripts/backfillNewsPostUrls.ts",
    "openapi": "tsx src/openapi/generate.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:reset": "prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts",
    "setup-db": "prisma migrate dev --skip-generate && prisma db seed",
    "test": "vitest run --coverage",
    "lint": "eslint ."
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@google-cloud/storage": "^7.21.0",
    "@hatchery/common": "workspace:*",
    "@prisma/client": "^6",
    "cheerio": "^1.2.0",
    "connect-pg-simple": "^10.0.0",
    "express": "^5.0.0",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.19.0",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.21.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/web-push": "^3.6.4",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5",
    "@types/express-session": "^1.19.0",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6",
    "openapi3-ts": "^4.5.0",
    "prisma": "^6",
    "supertest": "^7",
    "tsx": "^4"
  }
}
