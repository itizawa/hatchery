{
  "name": "@hatchery/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -b",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "batch": "tsx src/batch/index.ts",
    "openapi": "tsx src/openapi/generate.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "setup-db": "prisma migrate dev --skip-generate && prisma db seed",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@hatchery/common": "workspace:*",
    "@octokit/rest": "^22.0.1",
    "@prisma/client": "^6",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "express": "^5.0.0",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.19.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5",
    "@types/express-session": "^1.19.0",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6",
    "openapi3-ts": "^4.5.0",
    "prisma": "^6",
    "supertest": "^7",
    "tsx": "^4"
  }
}
