// Hatchery MVP の永続化スキーマ（ADR-0004 / Issue #6 / ADR-0009 / Issue #27）。
// common（@hatchery/common）のドメイン型に対応する最小構成。
// 社員・チャンネル・メッセージ（channel 直接紐づき）・タスク（new/done）。
// Scene は ADR-0009 で廃止した。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 認証ユーザー（Issue #26 / ADR-0009）。パスワードは bcrypt ハッシュで保存する。
model User {
  id           String    @id
  displayName  String
  passwordHash String
  /// 1 ユーザー = 1 Employee の任意リレーション（#49）。
  employee     Employee?
}

/// AI 社員。common の EmployeeSchema に対応（id / displayName / role? / isBot）。
model Employee {
  id          String            @id
  displayName String
  role        String?
  /// AI 社員は true、ユーザー所有社員は false（#49）。
  isBot       Boolean           @default(false)
  /// ユーザー所有社員のみ User と 1:1 で紐づく。AI 社員は null（#49）。
  userId      String?           @unique
  user        User?             @relation(fields: [userId], references: [id])
  tasks       Task[]
  channels    ChannelEmployee[]
}

/// 話題の入れ物。common の ChannelSchema に対応（id / label）。
model Channel {
  id      String            @id
  label   String
  members ChannelEmployee[]
}

/// Employee ↔ Channel の所属（多対多）の明示的中間テーブル（#33）。
/// 1 人の Employee が複数チャンネルに所属でき、1 チャンネルに複数 Employee が所属できる。
model ChannelEmployee {
  channelId  String
  employeeId String
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@id([channelId, employeeId])
  @@index([employeeId])
}

/// channel に直接紐づく 1 発言（ADR-0009: Scene 廃止）。
/// createdAt でバッチ間の時系列順を保ち、order でバッチ内の発言順を保つ。
model Message {
  id        String   @id @default(cuid())
  speaker   String
  channel   String
  text      String
  createdAt DateTime @default(now())
  order     Int

  @@index([channel, createdAt])
}

/// MVP のタスク状態（common の TaskStatusSchema に対応）。
enum TaskStatus {
  new
  done
}

/// 社員が抱えるタスク。common の TaskSchema に対応（id / text / status）。
model Task {
  id         String     @id
  text       String
  status     TaskStatus @default(new)
  employee   Employee?  @relation(fields: [employeeId], references: [id])
  employeeId String?
}
